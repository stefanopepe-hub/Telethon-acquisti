# Supabase (trovi questi valori in: https://supabase.com → tuo progetto → Settings → API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...

# Anthropic (https://console.anthropic.com/api-keys)
ANTHROPIC_API_KEY=sk-ant-...

# Chiave admin per le API di gestione dati (scegli una stringa sicura)
ADMIN_KEY=cambia-questa-chiave-segreta

# Railway imposta PORT automaticamente, non serve cambiarlo
PORT=3000
